#!/usr/bin/env bash
#
# atelier-vercel — thin wrapper over the official Vercel CLI, for atelier agents.
#
# Auth is per-project: VERCEL_TOKEN (and optional VERCEL_ORG_ID /
# VERCEL_PROJECT_ID) are read from the current project's .env (kept gitignored
# by atelier's .env* guardrail) or from the environment. Exposes a small,
# auditable set of subcommands. Production-affecting writes (deploy-prod,
# promote, rollback, redeploy, env-add) are left out of atelier's allowlist so
# Claude Code asks the operator before running them, and destructive operations
# (remove, env-rm, project-rm) additionally require an in-CLI confirmation
# (--yes or an interactive y/N) before the vendor CLI is invoked.
#
set -euo pipefail
IFS=$'\n\t'

VERSION="0.3.0"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"

log()  { printf '==> %s\n' "$*"; }
die()  { printf '!!  ERROR: %s\n' "$*" >&2; exit 1; }
require() { command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"; }

# atelier user-level settings.json (persists across tasks; never the per-task
# template). Resolution order mirrors how atelier/Claude Code locate it.
ATELIER_SETTINGS="${VERCEL_ATELIER_SETTINGS:-${ATELIER_CONFIG_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}}/settings.json}"

# Permissions granted to agents for routine Vercel operations: read ops and
# preview deploys only. Production-affecting writes (deploy-prod, promote,
# rollback, redeploy, env-add) and destructive commands (remove, env-rm,
# project-rm) are intentionally absent so they fall through to Claude Code's
# default "ask" prompt and the operator confirms.
VERCEL_ALLOW='[
  "Bash(atelier-vercel whoami:*)",
  "Bash(atelier-vercel list:*)",
  "Bash(atelier-vercel inspect:*)",
  "Bash(atelier-vercel logs:*)",
  "Bash(atelier-vercel env-ls:*)",
  "Bash(atelier-vercel deploy:*)",
  "Bash(atelier-vercel link:*)",
  "Bash(atelier-vercel pull:*)",
  "Skill(vercel-integration:*)"
]'

# Entries granted by previous releases that must no longer be auto-allowed.
# enable-permissions strips these on upgrade and disable-permissions removes
# them too, so stale grants in an existing settings.json get cleaned up.
VERCEL_REVOKED='[
  "Bash(atelier-vercel deploy-prod:*)",
  "Bash(atelier-vercel env-add:*)",
  "Bash(atelier-vercel redeploy:*)",
  "Bash(atelier-vercel rollback:*)",
  "Bash(atelier-vercel promote:*)"
]'

usage() {
  cat <<EOF
${SCRIPT_NAME} ${VERSION}

Thin wrapper over the official Vercel CLI. Reads VERCEL_TOKEN (and optional
VERCEL_ORG_ID / VERCEL_PROJECT_ID) from the current project's .env (or the
environment). Uses an installed \`vercel\`, else \`pnpm dlx vercel@latest\`.

USAGE
  ${SCRIPT_NAME} <command> [args]

READ-ONLY
  whoami                       Current Vercel scope/user
  list [app]                   List deployments
  inspect <url|id>             Deployment details
  logs <url|id>                Deployment logs
  env-ls                       List project env vars (names)

WRITE (in atelier allowlist)
  deploy [path]                Preview deployment
  link [path]                  Link directory to a Vercel project
  pull                         Pull project settings/env into .vercel

PRODUCTION (left out of allowlist — Claude Code asks the operator first)
  deploy-prod [path]           Production deployment (vercel deploy --prod)
  env-add <name> [target]      Add an env var (value read from stdin)
  redeploy <url|id>            Rebuild + redeploy
  rollback [url|id]            Revert to a previous deployment
  promote <url|id>             Promote a deployment to current

DESTRUCTIVE (left out of allowlist AND confirmed in-CLI: pass --yes, or
answer the interactive y/N prompt; non-interactive without --yes fails)
  remove [--yes] <url|id>      Delete a deployment
  env-rm [--yes] <name> [target]  Remove an env var
  project-rm [--yes] <name>    Delete a project

SETUP
  configure [--non-interactive]  PATH launcher + permissions, then (inside a project)
                               write VERCEL_TOKEN to its .env.
  link-cli [target]            Install a self-resolving launcher onto PATH
                               (default ~/.local/bin); it re-resolves the active
                               plugin install on every run, so plugin updates
                               never leave the command stale
  enable-permissions           Merge the allowlist into atelier user settings.json
  disable-permissions          Remove that allowlist

ENVIRONMENT
  VERCEL_TOKEN                 Required. Vercel access token.
  VERCEL_ORG_ID               Optional. Team/scope id.
  VERCEL_PROJECT_ID           Optional. Project id (for non-interactive scope).
  VERCEL_ENV_FILE             Optional. Path to the project .env (default: .env)
EOF
}

# Load VERCEL_* from the project's .env without leaking unrelated variables.
# Real environment values take precedence.
_load_project_env() {
  local f="${VERCEL_ENV_FILE:-.env}" line key val
  [ -f "$f" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      VERCEL_TOKEN=*|VERCEL_ORG_ID=*|VERCEL_PROJECT_ID=*)
        key="${line%%=*}"
        val="${line#*=}"
        val="${val%\"}"; val="${val#\"}"
        val="${val%\'}"; val="${val#\'}"
        if [ -z "${!key:-}" ]; then export "$key=$val"; fi
        ;;
    esac
  done < "$f"
}

vercel_cli() {
  if command -v vercel >/dev/null 2>&1; then
    vercel "$@"
  else
    require pnpm
    pnpm dlx vercel@latest "$@"
  fi
}

# Ensure the vercel CLI is installed so deploys are fast (no per-call pnpm dlx
# download). Best-effort: a failed global install is non-fatal — vercel_cli's
# pnpm dlx fallback still works.
_ensure_cli() {
  if command -v vercel >/dev/null 2>&1; then
    log "vercel CLI present ($(command -v vercel))"
    return 0
  fi
  if command -v pnpm >/dev/null 2>&1; then
    log "vercel CLI not found — installing globally (pnpm add -g vercel)"
    if pnpm add -g vercel >/dev/null 2>&1; then
      log "vercel installed"
    else
      log "global install failed — the wrapper will fall back to 'pnpm dlx vercel@latest'"
    fi
  else
    log "no pnpm and no vercel — install one; the wrapper errors without either"
  fi
}

# Run an authenticated vercel command (loads .env, requires token).
vrun() {
  _load_project_env
  [ -n "${VERCEL_TOKEN:-}" ] || die "set VERCEL_TOKEN in this project's .env"
  vercel_cli "$@"
}

cmd_whoami()      { vrun whoami; }
cmd_list()        { vrun ls "$@"; }
cmd_inspect()     { vrun inspect "${1:?url|id required}"; }
cmd_logs()        { vrun logs "${1:?url|id required}"; }
cmd_env_ls()      { vrun env ls "$@"; }
cmd_deploy()      { vrun deploy "$@"; }
cmd_deploy_prod() { vrun deploy --prod "$@"; }
cmd_env_add()     { vrun env add "${1:?name required}" "${2:-production}"; }
cmd_redeploy()    { vrun redeploy "${1:?url|id required}"; }
cmd_rollback()    { vrun rollback "$@"; }
cmd_promote()     { vrun promote "${1:?url|id required}"; }
cmd_link()        { vrun link "$@"; }
cmd_pull()        { vrun pull "$@"; }
# Confirmation gate for destructive commands. The wrappers below pass --yes to
# the vendor CLI (bypassing its own prompt), so the wrapper must own the
# confirmation: an explicit --yes flag, or an interactive y/N on a TTY.
# Non-interactive without --yes dies before the vendor CLI is ever invoked.
_confirm_destructive() {
  local op="$1" detail="$2" assume_yes="$3" reply
  [ "$assume_yes" = "true" ] && return 0
  if [ ! -t 0 ]; then
    die "'${op}' is destructive and needs confirmation: re-run with --yes, or run it from an interactive terminal (${detail})"
  fi
  printf "About to run '%s' — %s. Continue? [y/N] " "$op" "$detail" >&2
  IFS= read -r reply
  case "$reply" in
    y|Y|yes|YES) ;;
    *) die "aborted '${op}' (no confirmation)" ;;
  esac
}

# Strip a --yes flag out of "$@" into ARGS_YES / ARGS_REST (bash 3.2 safe).
_split_yes() {
  ARGS_YES=false
  ARGS_REST=()
  local a
  for a in "$@"; do
    case "$a" in
      --yes|-y) ARGS_YES=true ;;
      *) ARGS_REST+=("$a") ;;
    esac
  done
}

cmd_remove() {
  _split_yes "$@"
  local target="${ARGS_REST[0]:?url|id required}"
  _confirm_destructive "remove" "delete deployment ${target}" "$ARGS_YES"
  vrun remove --yes "$target"
}

cmd_env_rm() {
  _split_yes "$@"
  local name="${ARGS_REST[0]:?name required}" target="${ARGS_REST[1]:-production}"
  _confirm_destructive "env-rm" "remove env var ${name} from ${target}" "$ARGS_YES"
  vrun env rm "$name" "$target" --yes
}

cmd_project_rm() {
  _split_yes "$@"
  local name="${ARGS_REST[0]:?name required}"
  _confirm_destructive "project-rm" "PERMANENTLY delete project ${name} and all its deployments" "$ARGS_YES"
  vrun project rm "$name" --yes
}

cmd_enable_permissions() {
  require jq
  local file="$ATELIER_SETTINGS" tmp
  mkdir -p "$(dirname "$file")"
  [ -f "$file" ] || printf '{}\n' > "$file"
  jq empty "$file" 2>/dev/null || die "not valid JSON: ${file}"
  tmp="$(mktemp)"
  jq --argjson add "$VERCEL_ALLOW" --argjson revoked "$VERCEL_REVOKED" '
    .permissions = (.permissions // {})
    | .permissions.allow = (((.permissions.allow // []) - $revoked) as $cur
        | $cur + ($add - $cur))
  ' "$file" > "$tmp" && mv "$tmp" "$file"
  log "vercel permissions merged into ${file} (stale production grants stripped)"
}

cmd_disable_permissions() {
  require jq
  local file="$ATELIER_SETTINGS" tmp
  [ -f "$file" ] || { log "nothing to do (${file} does not exist)"; return 0; }
  jq empty "$file" 2>/dev/null || die "not valid JSON: ${file}"
  tmp="$(mktemp)"
  jq --argjson rm "$VERCEL_ALLOW" --argjson revoked "$VERCEL_REVOKED" '
    if .permissions.allow then .permissions.allow -= ($rm + $revoked) else . end
  ' "$file" > "$tmp" && mv "$tmp" "$file"
  log "vercel permissions removed from ${file}"
}

# Resolve this script's real path (following symlinks), portably for bash 3.2.
_self_path() {
  local src="${BASH_SOURCE[0]}" dir
  while [ -h "$src" ]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    case "$src" in /*) ;; *) src="${dir}/${src}" ;; esac
  done
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  printf '%s/%s' "$dir" "$(basename "$src")"
}

# Install a small self-resolving launcher onto PATH. A plain symlink to
# _self_path goes stale after every `claude plugin update` (the plugin cache
# path is versioned, e.g. .../vercel-integration/0.2.0/...), so the launcher
# re-resolves the active install from Claude Code's installed_plugins.json at
# every invocation and only falls back to the link-time path (git-clone / dev
# installs, or no manifest). Idempotent: re-linking rewrites the launcher.
cmd_link_cli() {
  local target="${1:-$HOME/.local/bin/atelier-vercel}" dir self tmp
  dir="$(dirname "$target")"
  mkdir -p "$dir"
  self="$(_self_path)"
  tmp="$(mktemp "${dir}/.atelier-vercel.XXXXXX")" || die "mktemp failed in ${dir}"
  {
    cat <<'LAUNCHER'
#!/usr/bin/env bash
# atelier-vercel launcher — installed by `atelier-vercel link-cli`. Resolves the
# ACTIVE plugin-cache version at every invocation via Claude Code's pointer
# file, so `claude plugin update` never leaves this command stale.
set -euo pipefail
manifest="${ATELIER_CONFIG_DIR:-$HOME/.claude-work}/plugins/installed_plugins.json"
root=""
[ -f "$manifest" ] && root="$(jq -r '.plugins["vercel-integration@akalab-tech"][0].installPath // empty' "$manifest" 2>/dev/null || true)"
if [ -n "$root" ] && [ -x "$root/scripts/atelier-vercel" ]; then
  exec "$root/scripts/atelier-vercel" "$@"
fi
# fallback: the path recorded at link time (git-clone / dev installs, or no manifest)
LAUNCHER
    printf 'fallback=%q\n' "$self"
    cat <<'LAUNCHER'
[ -x "$fallback" ] && exec "$fallback" "$@"
echo "atelier-vercel: no active install found (manifest: $manifest; fallback: $fallback)" >&2
echo "reinstall with: CLAUDE_CONFIG_DIR=\"\${ATELIER_CONFIG_DIR:-\$HOME/.claude-work}\" claude plugin install vercel-integration@akalab-tech" >&2
exit 1
LAUNCHER
  } > "$tmp"
  chmod +x "$tmp"
  # Remove the old target BEFORE installing: writing through an existing
  # symlink (e.g. a bare `>` redirect) follows it and would clobber the
  # plugin-cache script it points at. rm + mv replaces the name atomically
  # without ever writing through it.
  rm -f "$target"
  mv "$tmp" "$target"
  log "installed launcher -> ${target} (re-resolves the active plugin install on every run)"
  case ":${PATH}:" in
    *":${dir}:"*) ;;
    *) log "note: ${dir} is not on your PATH" ;;
  esac
}

_set_env_var() {
  local file="$1" key="$2" val="$3"
  touch "$file"
  if grep -q "^${key}=" "$file" 2>/dev/null; then
    log "${key} already present in ${file} — leaving it"
  else
    printf '%s=%s\n' "$key" "$val" >> "$file"
    log "added ${key} to ${file}"
  fi
}

cmd_configure() {
  local interactive=true
  [ "${1:-}" = "--non-interactive" ] && interactive=false
  [ -t 0 ] || interactive=false

  cmd_link_cli
  cmd_enable_permissions
  _ensure_cli

  if [ "$interactive" = false ]; then
    log "non-interactive — PATH + permissions done"
    log "per project: add VERCEL_TOKEN to that project's .env"
    return 0
  fi

  if [ -e .git ] || [ -f package.json ] || [ -f .env ]; then
    local envf="${VERCEL_ENV_FILE:-.env}" token
    if grep -q '^VERCEL_TOKEN=' "$envf" 2>/dev/null; then
      log "VERCEL_TOKEN already in ${envf}"
    else
      printf 'Vercel token for this project (input hidden, Enter to skip): '
      read -rs token; echo
      if [ -n "$token" ]; then _set_env_var "$envf" VERCEL_TOKEN "$token"; else log "skipped token"; fi
    fi
    log "auth lives in ${envf} (atelier keeps .env* gitignored)"
  else
    log "not inside a project — add VERCEL_TOKEN to a project's .env, then re-run from its directory."
  fi
}

main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    whoami)              cmd_whoami "$@" ;;
    list)                cmd_list "$@" ;;
    inspect)             cmd_inspect "$@" ;;
    logs)                cmd_logs "$@" ;;
    env-ls)              cmd_env_ls "$@" ;;
    deploy)              cmd_deploy "$@" ;;
    deploy-prod)         cmd_deploy_prod "$@" ;;
    env-add)             cmd_env_add "$@" ;;
    redeploy)            cmd_redeploy "$@" ;;
    rollback)            cmd_rollback "$@" ;;
    promote)             cmd_promote "$@" ;;
    link)                cmd_link "$@" ;;
    pull)                cmd_pull "$@" ;;
    remove)              cmd_remove "$@" ;;
    env-rm)              cmd_env_rm "$@" ;;
    project-rm)          cmd_project_rm "$@" ;;
    enable-permissions)  cmd_enable_permissions "$@" ;;
    disable-permissions) cmd_disable_permissions "$@" ;;
    configure)           cmd_configure "$@" ;;
    link-cli)            cmd_link_cli "$@" ;;
    -h|--help|help|"")   usage ;;
    *) die "unknown command: ${cmd} (try --help)" ;;
  esac
}

main "$@"
